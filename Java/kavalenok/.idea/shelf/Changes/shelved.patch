<+><!DOCTYPE html>\r\n<html lang=\"ru\" xmlns:th=\"http://www.thymeleaf.org\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title th:text=\"${pageTitle}\">Тренировки</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Condensed:wght@700&display=swap\" rel=\"stylesheet\">\r\n    <link th:href=\"@{/css/style.css}\" rel=\"stylesheet\">\r\n    <link rel=\"icon\" th:href=\"@{/img/favicon.jpg}\">\r\n</head>\r\n<body>\r\n\r\n<div th:replace=\"layout/header :: header\"></div>\r\n\r\n<section class=\"calendar-section\">\r\n    <div class=\"container\">\r\n        <div class=\"calendar-header fade-in\">\r\n            <h1 class=\"calendar-title\">Календарь тренировок</h1>\r\n            <p class=\"calendar-subtitle\">Выберите удобное время и запишитесь на тренировку</p>\r\n\r\n            <div th:if=\"${user != null && user.role.name() == 'COACH'}\" class=\"calendar-header-actions\">\r\n                <a th:href=\"@{/trainings/create}\" class=\"btn-add-training\">\r\n                    <i class=\"fas fa-plus\"></i>Добавить тренировку\r\n                </a>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"filters-card fade-in\">\r\n            <form th:action=\"@{/trainings}\" method=\"get\" class=\"row g-3 align-items-end\">\r\n                <div class=\"col-md-4\">\r\n                    <label for=\"titleFilter\" class=\"form-label fw-semibold\">Название</label>\r\n                    <div class=\"input-group\">\r\n                        <span class=\"input-group-text bg-light\"><i class=\"fas fa-search\"></i></span>\r\n                        <input type=\"text\" class=\"form-control\" id=\"titleFilter\" name=\"title\"\r\n                               th:value=\"${filterTitle}\" placeholder=\"Введите название...\">\r\n                    </div>\r\n                </div>\r\n                <div class=\"col-md-3\">\r\n                    <label for=\"locationFilter\" class=\"form-label fw-semibold\">Место</label>\r\n                    <div class=\"input-group\">\r\n                        <span class=\"input-group-text bg-light\"><i class=\"fas fa-map-marker-alt\"></i></span>\r\n                        <input type=\"text\" class=\"form-control\" id=\"locationFilter\" name=\"location\"\r\n                               th:value=\"${filterLocation}\" placeholder=\"Где?\">\r\n                    </div>\r\n                </div>\r\n                <div class=\"col-md-3\">\r\n                    <label for=\"coachFilter\" class=\"form-label fw-semibold\">Тренер</label>\r\n                    <select class=\"form-select\" id=\"coachFilter\" name=\"coachId\">\r\n                        <option value=\"\">Все тренеры</option>\r\n                        <option th:each=\"coach : ${coaches}\"\r\n                                th:value=\"${coach.id}\"\r\n                                th:text=\"${coach.firstName} + ' ' + ${coach.lastName}\"\r\n                                th:selected=\"${filterCoachId != null && filterCoachId == coach.id}\">\r\n                        </option>\r\n                    </select>\r\n                </div>\r\n                <div class=\"col-md-2 d-flex gap-2\">\r\n                    <button type=\"submit\" class=\"btn btn-primary flex-fill\">\r\n                        <i class=\"fas fa-filter me-1\"></i>Фильтр\r\n                    </button>\r\n                    <a th:href=\"@{/trainings}\" class=\"btn btn-outline-secondary flex-fill\">\r\n                        <i class=\"fas fa-undo me-1\"></i>Сброс\r\n                    </a>\r\n                </div>\r\n            </form>\r\n        </div>\r\n        <br>\r\n\r\n        <div th:if=\"${successMessage}\" class=\"alert alert-success\" th:text=\"${successMessage}\"></div>\r\n        <div th:if=\"${errorMessage}\" class=\"alert alert-danger\" th:text=\"${errorMessage}\"></div>\r\n\r\n        <div class=\"calendar-nav fade-in\">\r\n            <button class=\"btn-calendar-nav\" onclick=\"changeMonth(-1)\">\r\n                <i class=\"fas fa-chevron-left me-2\"></i>Предыдущий месяц\r\n            </button>\r\n            <div class=\"calendar-month\" id=\"currentMonth\">Январь 2024</div>\r\n            <button class=\"btn-calendar-nav\" onclick=\"changeMonth(1)\">\r\n                Следующий месяц<i class=\"fas fa-chevron-right ms-2\"></i>\r\n            </button>\r\n        </div>\r\n\r\n        <div class=\"training-list fade-in\">\r\n            <h3>Предстоящие тренировки</h3>\r\n\r\n            <div th:if=\"${trainings.isEmpty()}\" class=\"no-trainings\">\r\n                <i class=\"fas fa-calendar-times\"></i>\r\n                <h4>Тренировки не найдены</h4>\r\n                <p>Пока нет запланированных тренировок. Загляните позже!</p>\r\n            </div>\r\n\r\n            <div th:each=\"training : ${trainings}\" class=\"training-card fade-in\"\r\n                 th:classappend=\"${training.full ? 'full' : (training.dateTime.toLocalDate().isEqual(T(java.time.LocalDate).now()) ? 'today' : '')}\">\r\n                <div class=\"training-header\">\r\n                    <h4 class=\"training-title\" th:text=\"${training.title}\">Тренировка по волейболу</h4>\r\n                    <div class=\"training-time\" th:text=\"${training.formattedTime + ' - ' + training.durationHours}\">18:00 - 1.5ч</div>\r\n                </div>\r\n\r\n                <div class=\"training-info\">\r\n                    <div class=\"training-info-item\">\r\n                        <i class=\"fas fa-calendar training-info-icon\"></i>\r\n                        <div>\r\n                            <div class=\"training-info-label\">Дата</div>\r\n                            <div class=\"training-info-value\" th:text=\"${#temporals.format(training.dateTime, 'dd.MM.yyyy')}\">01.01.2024</div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"training-info-item\" th:if=\"${training.location != null}\">\r\n                        <i class=\"fas fa-map-marker-alt training-info-icon\"></i>\r\n                        <div>\r\n                            <div class=\"training-info-label\">Место</div>\r\n                            <div class=\"training-info-value\" th:text=\"${training.location}\">Спортивный зал #1</div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"training-info-item\">\r\n                        <i class=\"fas fa-users training-info-icon\"></i>\r\n                        <div>\r\n                            <div class=\"training-info-label\">Участники</div>\r\n                            <div class=\"training-info-value\"\r\n                                 th:text=\"${training.maxParticipants != null ? (training.currentParticipants + ' / ' + training.maxParticipants) : (training.currentParticipants + ' записано')}\">\r\n                                8 / 15\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"training-coach\" th:if=\"${training.coach != null}\">\r\n                    <img th:src=\"@{${training.coach.avatarUrl} ?: '/img/avatars/1.png'}\"\r\n                         class=\"coach-avatar\"\r\n                         alt=\"Аватар тренера\"\r\n                         onerror=\"this.src='/img/avatars/1.png'\">\r\n                    <div class=\"coach-name\" th:text=\"'Тренер: ' + ${training.coach.firstName} + ' ' + ${training.coach.lastName}\">\r\n                        Тренер: Иван Петров\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"training-actions\">\r\n                    <th:block th:if=\"${user != null}\">\r\n                        <th:block th:if=\"${registeredTrainingIds != null && registeredTrainingIds.contains(training.id)}\">\r\n                            <span class=\"badge bg-success py-2 px-3\">\r\n                                <i class=\"fas fa-check me-1\"></i>Вы записаны\r\n                            </span>\r\n                        </th:block>\r\n                        <th:block th:unless=\"${registeredTrainingIds != null && registeredTrainingIds.contains(training.id)}\">\r\n                            <form th:action=\"@{/trainings/register}\" method=\"post\" class=\"d-inline\">\r\n                                <input type=\"hidden\" name=\"trainingId\" th:value=\"${training.id}\">\r\n                                <button type=\"submit\" class=\"btn-register\"\r\n                                        th:disabled=\"${training.full}\"\r\n                                        th:title=\"${training.full} ? 'Тренировка заполнена' : 'Записаться на тренировку'\">\r\n                                    <i class=\"fas fa-user-plus me-2\"></i>\r\n                                    <span th:text=\"${training.full} ? 'Заполнено' : 'Записаться'\">Записаться</span>\r\n                                </button>\r\n                            </form>\r\n                        </th:block>\r\n                    </th:block>\r\n                    <th:block th:if=\"${user == null}\">\r\n                        <a th:href=\"@{/login}\" class=\"btn-register\">\r\n                            <i class=\"fas fa-sign-in-alt me-2\"></i>Войти для записи\r\n                        </a>\r\n                    </th:block>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<div th:replace=\"layout/footer :: footer\"></div>\r\n\r\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\r\n\r\n<script>\r\n    document.addEventListener('DOMContentLoaded', function () {\r\n        const cards = document.querySelectorAll('.training-card');\r\n        cards.forEach((card, index) => {\r\n            card.style.animationDelay = (index * 0.1) + 's';\r\n        });\r\n\r\n        const observer = new IntersectionObserver((entries) => {\r\n            entries.forEach(entry => {\r\n                if (entry.isIntersecting) {\r\n                    entry.target.classList.add('visible');\r\n                }\r\n            });\r\n        }, { threshold: 0.1 });\r\n\r\n        document.querySelectorAll('.fade-in').forEach(el => {\r\n            observer.observe(el);\r\n        });\r\n\r\n        let currentDate = new Date();\r\n        updateMonthDisplay();\r\n\r\n        window.changeMonth = function(months) {\r\n            currentDate.setMonth(currentDate.getMonth() + months);\r\n            updateMonthDisplay();\r\n        };\r\n\r\n        function updateMonthDisplay() {\r\n            const monthNames = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь',\r\n                'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];\r\n            const monthElement = document.getElementById('currentMonth');\r\n            monthElement.textContent = `${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`;\r\n        }\r\n    });\r\n</script>\r\n\r\n</body>\r\n</html>
