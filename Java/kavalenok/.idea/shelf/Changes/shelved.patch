data-panel=\"reports\">Жалобы</button>\r\n        <button type=\"button\" class=\"admin-tab\" data-panel=\"exports\">Экспорт статистики</button>\r\n    </div>\r\n\r\n    <div id=\"adminMessage\"></div>\r\n\r\n    <div id=\"panel-users\" class=\"admin-panel active\">\r\n        <div class=\"table-wrap\">\r\n            <table class=\"admin-table\">\r\n                <thead><tr><th>ID</th><th>Имя</th><th>Email / телефон</th><th>Роль</th><th>Статус</th><th></th></tr></thead>\r\n                <tbody id=\"usersBody\"></tbody>\r\n            </table>\r\n            <div id=\"usersEmpty\" class=\"empty-admin\" hidden>Нет пользователей</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"panel-listings-pending\" class=\"admin-panel\">\r\n        <div class=\"table-wrap\">\r\n            <table class=\"admin-table\">\r\n                <thead><tr><th>ID</th><th>Автор</th><th>Название</th><th>Город</th><th>Тип / цена</th><th></th></tr></thead>\r\n                <tbody id=\"pendingBody\"></tbody>\r\n            </table>\r\n            <div id=\"pendingEmpty\" class=\"empty-admin\" hidden>Очередь пуста</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"panel-listings-all\" class=\"admin-panel\">\r\n        <div class=\"admin-toolbar\">\r\n            <label>Статус модерации:\r\n                <select id=\"listingsStatusFilter\">\r\n                    <option value=\"all\">Все</option>\r\n                    <option value=\"pending\">На модерации</option>\r\n                    <option value=\"approved\">Опубликованные</option>\r\n                    <option value=\"rejected\">Отклонённые</option>\r\n                </select>\r\n            </label>\r\n            <label><input type=\"checkbox\" id=\"listingsIncludeInactive\"> Показать снятые </label>\r\n            <button type=\"button\" class=\"btn btn-outline btn-sm\" id=\"reloadListingsBtn\"> Обновить</button>\r\n        </div>\r\n        <div class=\"table-wrap\">\r\n            <table class=\"admin-table\">\r\n                <thead><tr><th>ID</th><th>Автор</th><th>Название</th><th>Статус</th><th>Активно</th><th></th></tr></thead>\r\n                <tbody id=\"allListingsBody\"></tbody>\r\n            </table>\r\n            <div id=\"allListingsEmpty\" class=\"empty-admin\" hidden>Нет объявлений</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"panel-reviews-pending\" class=\"admin-panel\">\r\n        <div class=\"table-wrap\">\r\n            <table class=\"admin-table\">\r\n                <thead><tr><th>ID</th><th>Объявление</th><th>Автор</th><th>Оценка</th><th>Текст</th><th></th></tr></thead>\r\n                <tbody id=\"pendingReviewsBody\"></tbody>\r\n            </table>\r\n            <div id=\"pendingReviewsEmpty\" class=\"empty-admin\" hidden>Нет отзывов на проверке</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"panel-reports\" class=\"admin-panel\">\r\n        <div class=\"admin-toolbar\">\r\n            <label>Статус:\r\n                <select id=\"reportsStatusFilter\">\r\n                    <option value=\"pending\">Новые</option>\r\n                    <option value=\"all\">Все</option>\r\n                    <option value=\"resolved\">Рассмотрено</option>\r\n                    <option value=\"dismissed\">Отклонено</option>\r\n                </select>\r\n            </label>\r\n            <button type=\"button\" class=\"btn btn-outline btn-sm\" id=\"reloadReportsBtn\"> Обновить</button>\r\n        </div>\r\n        <div class=\"table-wrap\">\r\n            <table class=\"admin-table\">\r\n                <thead><tr><th>ID</th><th>Кто пожаловался</th><th>На кого</th><th>Объявление</th><th>Причина</th><th>Статус</th><th></th></tr></thead>\r\n                <tbody id=\"reportsBody\"></tbody>\r\n            </table>\r\n            <div id=\"reportsEmpty\" class=\"empty-admin\" hidden>Нет жалоб</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"panel-exports\" class=\"admin-panel\">\r\n        <div class=\"table-wrap\" style=\"padding:20px;\">\r\n            <h3 style=\"margin-top:0;\">Скачать статистику</h3>\r\n            <p style=\"color:var(--text-muted); margin-bottom:16px;\">Экспортируется отдельно в JSON.</p>\r\n            <div class=\"row-actions\" style=\"display:flex;flex-direction:column;align-items:flex-start;gap:10px;\">\r\n                <button type=\"button\" class=\"btn btn-primary btn-sm\" id=\"exportUsersJsonBtn\">Пользователи JSON</button>\r\n                <button type=\"button\" class=\"btn btn-primary btn-sm\" id=\"exportPopularityJsonBtn\">Популярность объявлений JSON</button>\r\n                <button type=\"button\" class=\"btn btn-primary btn-sm\" id=\"exportReportsJsonBtn\">Жалобы JSON</button>\r\n                <button type=\"button\" class=\"btn btn-primary btn-sm\" id=\"exportReviewsJsonBtn\">Отзывы JSON</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</main>\r\n\r\n<div class=\"modal-overlay\" id=\"userModal\" aria-hidden=\"true\">\r\n    <div class=\"modal-box\">\r\n        <h2>Профиль пользователя</h2>\r\n        <div id=\"userModalContent\"></div>\r\n        <div class=\"modal-actions\">\r\n            <button type=\"button\" class=\"btn btn-danger\" id=\"userModalBlock\">Заблокировать</button>\r\n            <button type=\"button\" class=\"btn btn-primary\" id=\"userModalUnblock\">Разблокировать</button>\r\n            <button type=\"button\" class=\"btn btn-outline\" id=\"userModalClose\">Закрыть</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<div class=\"modal-overlay\" id=\"listingModal\" aria-hidden=\"true\">\r\n    <div class=\"modal-box wide\">\r\n        <h2>Редактирование объявления</h2>\r\n        <form id=\"listingEditForm\">\r\n            <input type=\"hidden\" id=\"editListingId\">\r\n            <div class=\"modal-grid\">\r\n                <div class=\"full\"><label>Название</label><input type=\"text\" id=\"editTitle\" required></div>\r\n                <div class=\"full\"><label>Описание</label><textarea id=\"editDescription\" rows=\"4\" required></textarea></div>\r\n                <div><label>Тип</label>\r\n                    <select id=\"editListingType\"><option value=\"rent\">Аренда</option><option value=\"sale\">Продажа</option></select>\r\n                </div>\r\n                <div><label>Модерация</label>\r\n                    <select id=\"editModeration\"><option value=\"pending\">На модерации</option><option value=\"approved\">Одобрено</option><option value=\"rejected\">Отклонено</option></select>\r\n                </div>\r\n                <div><label>Цена (BYN)</label><input type=\"number\" id=\"editPrice\" step=\"0.01\" min=\"0\"></div>\r\n                <div><label>Комнаты</label><input type=\"number\" id=\"editRooms\" min=\"0\"></div>\r\n                <div><label>Площадь м²</label><input type=\"number\" id=\"editArea\" step=\"0.1\" min=\"0\"></div>\r\n                <div><label>Этаж</label><input type=\"number\" id=\"editFloor\" min=\"0\"></div>\r\n                <div><label>Этажей в доме</label><input type=\"number\" id=\"editTotalFloors\" min=\"0\"></div>\r\n                <div class=\"full\"><label>Адрес</label><input type=\"text\" id=\"editAddress\"></div>\r\n                <div><label>Город</label><input type=\"text\" id=\"editCity\"></div>\r\n                <div><label>Район</label><input type=\"text\" id=\"editDistrict\"></div>\r\n                <div><label>Доступно с (YYYY-MM-DD)</label><input type=\"text\" id=\"editAvailableFrom\" placeholder=\"пусто или дата\"></div>\r\n                <div><label>Залог</label><input type=\"text\" id=\"editDeposit\" placeholder=\"none / month / half\"></div>\r\n                <div><label>Коммунальные включены</label><select id=\"editUtilities\"><option value=\"false\">Нет</option><option value=\"true\">Да</option></select></div>\r\n                <div class=\"full\"><label>Фото (URL через запятую)</label><textarea id=\"editPhotos\" rows=\"2\" placeholder=\"/static/uploads/listings/1_0.jpg,...\"></textarea></div>\r\n            </div>\r\n            <div class=\"modal-actions\">\r\n                <button type=\"submit\" class=\"btn btn-primary\">Сохранить</button>\r\n                <button type=\"button\" class=\"btn btn-outline\" id=\"listingModalClose\">Отмена</button>\r\n            </div>\r\n        </form>\r\n    </div>\r\n</div>\r\n\r\n\r\n<footer class=\"footer\"></footer>\r\n\r\n<script src=\"/static/js/admin.js\"></script>\r\n<script src=\"/static/js/components.js\"></script>\r\n<script src=\"/static/js/script.js\"></script>\r\n</body>\r\n</html>
