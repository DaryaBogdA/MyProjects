<+><!DOCTYPE html>\r\n<html lang=\"ru\" xmlns:th=\"http://www.thymeleaf.org\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Чат с <span th:text=\"${friendName}\"></span></title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <link th:href=\"@{/css/style.css}\" rel=\"stylesheet\">\r\n</head>\r\n<body>\r\n\r\n<div th:replace=\"layout/header :: header\"></div>\r\n\r\n<section class=\"coaches-section\">\r\n    <div class=\"container chat-container\">\r\n        <div class=\"d-flex align-items-center mb-4\">\r\n            <a th:href=\"@{/messages}\" class=\"btn btn-outline-secondary me-3\">\r\n                <i class=\"fas fa-arrow-left\"></i>\r\n            </a>\r\n            <h2 th:text=\"${friendName}\" class=\"mb-0\">Имя друга</h2>\r\n        </div>\r\n\r\n        <div th:if=\"${errorMessage}\" class=\"alert alert-danger\" th:text=\"${errorMessage}\"></div>\r\n\r\n        <div class=\"bg-light rounded p-4 mb-4\" style=\"min-height: 400px; max-height: 500px; overflow-y: auto;\">\r\n            <div th:if=\"${#lists.isEmpty(messages)}\" class=\"text-center text-muted py-5\">\r\n                <i class=\"fas fa-comments fa-3x mb-3\"></i>\r\n                <p>У вас пока нет сообщений. Напишите первое!</p>\r\n            </div>\r\n\r\n            <div th:each=\"msg : ${messages}\" class=\"mb-3 d-flex\"\r\n                 th:classappend=\"${msg.sender.id == session.user.id} ? 'justify-content-end' : 'justify-content-start'\">\r\n                <div class=\"p-3 rounded shadow-sm message-bubble\"\r\n                     th:classappend=\"${msg.sender.id == session.user.id} ? 'bg-primary text-white' : 'bg-white'\">\r\n                    <div th:text=\"${msg.content}\" class=\"mb-1\">Текст сообщения</div>\r\n                    <div class=\"message-time d-flex justify-content-between align-items-center\">\r\n                        <span th:text=\"${#temporals.format(msg.sentAt, 'HH:mm')}\">12:34</span>\r\n                        <span th:if=\"${msg.sender.id == session.user.id}\" class=\"ms-2\">\r\n                            <i th:if=\"${msg.isRead}\" class=\"fas fa-check-double text-light\"></i>\r\n                            <i th:unless=\"${msg.isRead}\" class=\"fas fa-check text-light\"></i>\r\n                        </span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <form th:action=\"@{/messages/send}\" method=\"post\" class=\"d-flex gap-2\">\r\n            <input type=\"hidden\" name=\"receiverId\" th:value=\"${friendId}\">\r\n            <input type=\"text\" name=\"content\" class=\"form-control\" placeholder=\"Введите сообщение...\" required>\r\n            <button type=\"submit\" class=\"btn btn-primary\">\r\n                <i class=\"fas fa-paper-plane\"></i>\r\n            </button>\r\n        </form>\r\n    </div>\r\n</section>\r\n\r\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\r\n\r\n<div th:replace=\"layout/footer :: footer\"></div>\r\n\r\n<script>\r\n    window.onload = function() {\r\n        const chatBox = document.querySelector('.bg-light');\r\n        if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;\r\n    };\r\n</script>\r\n\r\n</body>\r\n</html>
