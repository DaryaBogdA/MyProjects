<+><!DOCTYPE html>\r\n<html lang=\"ru\" xmlns:th=\"http://www.thymeleaf.org\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Вход в VolleyPro</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Condensed:wght@700&display=swap\" rel=\"stylesheet\">\r\n    <link th:href=\"@{/css/style.css}\" rel=\"stylesheet\">\r\n    <link rel=\"icon\" th:href=\"@{/img/favicon.jpg}\">\r\n</head>\r\n<body>\r\n\r\n<div th:replace=\"layout/header :: header\"></div>\r\n\r\n<div class=\"register-container\">\r\n    <div class=\"login-card\">\r\n        <div class=\"login-header\">\r\n            <div class=\"login-logo\">\r\n                <img th:src=\"@{/img/favicon.jpg}\" alt=\"VolleyPro\">\r\n                <span class=\"login-logo-text\">VolleyPro</span>\r\n            </div>\r\n            <h2 class=\"mb-2\">С возвращением!</h2>\r\n            <p class=\"login-subtitle\">Войдите в свой аккаунт</p>\r\n        </div>\r\n\r\n        <div class=\"login-body\">\r\n            <div th:if=\"${errorMessage}\" class=\"alert alert-danger\" role=\"alert\">\r\n                <i class=\"fas fa-exclamation-circle me-2\"></i>\r\n                <span th:text=\"${errorMessage}\">Ошибка</span>\r\n            </div>\r\n\r\n            <form th:action=\"@{/login}\" method=\"post\" id=\"loginForm\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"email\" class=\"form-label\">\r\n                        <i class=\"fas fa-envelope\"></i>\r\n                        Email\r\n                    </label>\r\n                    <input type=\"email\"\r\n                           class=\"form-control\"\r\n                           id=\"email\"\r\n                           name=\"email\"\r\n                           placeholder=\"Введите ваш email\"\r\n                           th:value=\"${email}\"\r\n                           required\r\n                           autofocus>\r\n                </div>\r\n\r\n                <div class=\"form-group\">\r\n                    <label for=\"password\" class=\"form-label\">\r\n                        <i class=\"fas fa-lock\"></i>\r\n                        Пароль\r\n                    </label>\r\n                    <div class=\"input-group\">\r\n                        <input type=\"password\"\r\n                               class=\"form-control\"\r\n                               id=\"password\"\r\n                               name=\"password\"\r\n                               placeholder=\"Введите ваш пароль\"\r\n                               required>\r\n                        <span class=\"input-group-text password-toggle\" onclick=\"togglePassword('password', this)\">\r\n                            <i class=\"fas fa-eye\"></i>\r\n                        </span>\r\n                    </div>\r\n                </div>\r\n\r\n                <button type=\"submit\" class=\"btn btn-login\" id=\"loginButton\">\r\n                    <span id=\"loginText\">Войти</span>\r\n                    <i class=\"fas fa-sign-in-alt\"></i>\r\n                </button>\r\n            </form>\r\n\r\n            <div class=\"divider\">\r\n                <span>Нет аккаунта?</span>\r\n            </div>\r\n\r\n            <div class=\"text-center\">\r\n                <p class=\"mb-3\">Создайте новый аккаунт</p>\r\n                <a th:href=\"@{/register}\" class=\"btn btn-outline-primary\" style=\"width: 100%; padding: 14px;\">\r\n                    <i class=\"fas fa-user-plus me-2\"></i>\r\n                    Зарегистрироваться\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<div th:replace=\"layout/footer :: footer\"></div>\r\n\r\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\r\n<script>\r\n    function togglePassword(inputId, toggleElement) {\r\n        const input = document.getElementById(inputId);\r\n        const icon = toggleElement.querySelector('i');\r\n\r\n        if (input.type === 'password') {\r\n            input.type = 'text';\r\n            icon.classList.remove('fa-eye');\r\n            icon.classList.add('fa-eye-slash');\r\n        } else {\r\n            input.type = 'password';\r\n            icon.classList.remove('fa-eye-slash');\r\n            icon.classList.add('fa-eye');\r\n        }\r\n    }\r\n\r\n    document.addEventListener('DOMContentLoaded', function() {\r\n        const emailInput = document.getElementById('email');\r\n        if (emailInput.value === '') {\r\n            emailInput.focus();\r\n        }\r\n    });\r\n\r\n    document.getElementById('loginForm').addEventListener('submit', function() {\r\n        const button = document.getElementById('loginButton');\r\n        const text = document.getElementById('loginText');\r\n        button.disabled = true;\r\n        text.textContent = 'Вход...';\r\n    });\r\n</script>\r\n</body>\r\n</html>
