<+><!DOCTYPE html>\r\n<html lang=\"ru\" xmlns:th=\"http://www.thymeleaf.org\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title th:text=\"${pageTitle}\">Личный кабинет</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Condensed:wght@700&display=swap\"\r\n          rel=\"stylesheet\">\r\n    <link th:href=\"@{/css/style.css}\" rel=\"stylesheet\">\r\n    <link rel=\"icon\" th:href=\"@{/img/favicon.jpg}\">\r\n</head>\r\n<body>\r\n\r\n<div th:replace=\"layout/header :: header\"></div>\r\n\r\n<section class=\"profile-section\">\r\n    <div class=\"container\">\r\n        <div th:if=\"${successMessage}\" class=\"alert alert-success\" th:text=\"${successMessage}\"></div>\r\n        <div th:if=\"${errorMessage}\" class=\"alert alert-danger\" th:text=\"${errorMessage}\"></div>\r\n        <div class=\"row fade-in\">\r\n            <div class=\"col-lg-4 mb-4\">\r\n                <div class=\"profile-card\">\r\n                    <div class=\"profile-header text-center\">\r\n                        <img th:src=\"@{${user.avatarUrl} ?: '/img/avatars/1.png'}\"\r\n                             class=\"profile-avatar\"\r\n                             alt=\"Аватар пользователя\"\r\n                             onerror=\"this.src='/img/avatars/1.png'\">\r\n                        <h1 class=\"profile-name\" th:text=\"${user.firstName} + ' ' + ${user.lastName}\">\r\n                        </h1>\r\n                        <p class=\"profile-role\" th:text=\"${user.role}\">\r\n                        </p>\r\n                        <span class=\"profile-badge\">\r\n                            <i class=\"fas fa-star me-1\"></i>\r\n                            <span th:text=\"${user.rating}\">\r\n                            </span>\r\n                        </span>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"info-card fade-in\" style=\"animation-delay: 0.2s\">\r\n                    <h5><i class=\"fas fa-bolt me-2\"></i>Быстрые действия</h5>\r\n                    <div class=\"action-buttons\">\r\n                        <a th:href=\"@{/friends}\" class=\"btn-action btn-primary-action text-decoration-none text-center\">\r\n                            <i class=\"fas fa-user-friends\"></i>Найти друга\r\n                        </a>\r\n                        <th:block th:if=\"${user.role.name() == 'COACH'}\">\r\n                            <a th:href=\"@{/trainings/create}\"\r\n                               class=\"btn-action btn-secondary-action text-decoration-none\">\r\n                                <i class=\"fas fa-plus\"></i>Добавить тренировку\r\n                            </a>\r\n                        </th:block>\r\n                        <th:block th:if=\"${user.role.name() == 'COACH'}\">\r\n                            <a th:href=\"@{/teams/create}\" class=\"btn-action btn-secondary-action text-decoration-none\">\r\n                                <i class=\"fas fa-users\"></i>Создать команду\r\n                            </a>\r\n                        </th:block>\r\n                        <a th:href=\"@{/moreinfo}\" class=\"btn-action btn-secondary-action text-decoration-none\">\r\n                            <i class=\"fas fa-edit\"></i>Редактировать профиль\r\n                        </a>\r\n                        <a th:href=\"@{/trainings}\" class=\"btn-action btn-secondary-action text-decoration-none\">\r\n                            <i class=\"fas fa-search\"></i>Найти тренировку\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"col-lg-8\">\r\n                <div class=\"info-card fade-in\" style=\"animation-delay: 0.25s\">\r\n                    <h5><i class=\"fas fa-volleyball-ball me-2\"></i>Мои тренировки</h5>\r\n                    <div th:if=\"${myTrainings == null || myTrainings.isEmpty()}\" class=\"text-muted\">\r\n                        <p>Вы пока не записаны на тренировки. <a th:href=\"@{/trainings}\">Найти тренировку</a></p>\r\n                    </div>\r\n                    <a th:href=\"@{/profile/export-trainings}\" class=\"btn btn-success btn-sm\">\r\n                        <i class=\"fas fa-download me-1\"></i>Экспорт CSV\r\n                    </a>\r\n                    <div th:if=\"${myTrainings != null && !myTrainings.isEmpty()}\">\r\n                        <div th:each=\"training : ${myTrainings}\" class=\"my-training-item\">\r\n                            <div class=\"d-flex justify-content-between align-items-center\">\r\n                                <div>\r\n                                    <strong th:text=\"${training.title}\">Тренировка</strong>\r\n                                    <span class=\"text-muted ms-2\"\r\n                                          th:text=\"${#temporals.format(training.dateTime, 'dd.MM.yyyy HH:mm')}\">01.01.2024 18:00</span>\r\n                                </div>\r\n                                <form th:action=\"@{/trainings/unregister}\" method=\"post\" class=\"d-inline\">\r\n                                    <input type=\"hidden\" name=\"trainingId\" th:value=\"${training.id}\">\r\n                                    <button type=\"submit\" class=\"btn btn-sm btn-outline-danger\">Отписаться</button>\r\n                                </form>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"info-card fade-in\" style=\"animation-delay: 0.35s\">\r\n                    <h5><i class=\"fas fa-user-friends me-2\"></i>Мои друзья</h5>\r\n                    <div th:if=\"${friends == null || friends.isEmpty()}\" class=\"text-muted\">\r\n                        <p>У вас пока нет друзей. <a th:href=\"@{/friends}\">Найти друзей</a></p>\r\n                    </div>\r\n                    <div th:if=\"${friends != null && !friends.isEmpty()}\">\r\n                        <div class=\"row\">\r\n                            <div th:each=\"friend : ${friends}\" class=\"col-md-6 mb-3\">\r\n                                <div class=\"d-flex align-items-center border rounded p-2\">\r\n                                    <img th:src=\"@{${friend.avatarUrl} ?: '/img/avatars/1.png'}\"\r\n                                         class=\"rounded-circle me-3\"\r\n                                         width=\"50\"\r\n                                         height=\"50\"\r\n                                         alt=\"Аватар\"\r\n                                         onerror=\"this.src='/img/avatars/1.png'\">\r\n                                    <div class=\"flex-grow-1\">\r\n                                        <a th:href=\"@{/profile/{id}(id=${friend.id})}\"\r\n                                           class=\"text-decoration-none\">\r\n                                            <strong th:text=\"${friend.firstName} + ' ' + ${friend.lastName}\"></strong>\r\n                                        </a>\r\n                                        <div class=\"text-muted small\" th:text=\"${friend.email}\"></div>\r\n                                    </div>\r\n                                    <a th:href=\"@{/user/friends}\" class=\"btn btn-sm btn-outline-primary\">\r\n                                        <i class=\"fas fa-users\"></i>\r\n                                    </a>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"mt-3\">\r\n                            <a th:href=\"@{/user/friends}\" class=\"btn btn-outline-primary w-100\">\r\n                                <i class=\"fas fa-list me-2\"></i>Все друзья\r\n                            </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"info-card fade-in\" style=\"animation-delay: 0.3s\">\r\n                    <h5><i class=\"fas fa-user-circle me-2\"></i>Личная информация</h5>\r\n\r\n                    <div class=\"info-item\">\r\n                        <div class=\"info-icon\">\r\n                            <i class=\"fas fa-envelope\"></i>\r\n                        </div>\r\n                        <div class=\"info-content\">\r\n                            <h6>Email</h6>\r\n                            <p th:text=\"${user.email}\">\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"info-item\">\r\n                        <div class=\"info-icon\">\r\n                            <i class=\"fas fa-phone\"></i>\r\n                        </div>\r\n                        <div class=\"info-content\">\r\n                            <h6>Телефон</h6>\r\n                            <p th:text=\"${user.phone} ?: 'Не указан'\">\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"info-item\">\r\n                        <div class=\"info-icon\">\r\n                            <i class=\"fas fa-birthday-cake\"></i>\r\n                        </div>\r\n                        <div class=\"info-content\">\r\n                            <h6>Дата рождения</h6>\r\n                            <p th:text=\"${user.date != null ? #temporals.format(user.date, 'dd.MM.yyyy') : 'Не указана'}\">\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<div th:replace=\"layout/footer :: footer\"></div>\r\n\r\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\r\n\r\n<script>\r\n    document.addEventListener('DOMContentLoaded', function () {\r\n\r\n        const cards = document.querySelectorAll('.profile-card, .info-card');\r\n        cards.forEach((card, index) => {\r\n            card.style.animationDelay = (index * 0.1) + 's';\r\n        });\r\n\r\n        const observer = new IntersectionObserver((entries) => {\r\n            entries.forEach(entry => {\r\n                if (entry.isIntersecting) {\r\n                    entry.target.classList.add('visible');\r\n                }\r\n            });\r\n        }, {threshold: 0.1});\r\n\r\n        document.querySelectorAll('.fade-in').forEach(el => {\r\n            observer.observe(el);\r\n        });\r\n    });\r\n</script>\r\n\r\n</body>\r\n</html>
