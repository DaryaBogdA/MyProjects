halkboard-teacher me-1\"></i> Тренер:\r\n                            <span th:text=\"${team.captain.firstName} + ' ' + ${team.captain.lastName}\"></span>\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"coach-body\">\r\n                        <p th:text=\"${team.description ?: 'Описание отсутствует'}\" class=\"text-muted\">\r\n                        </p>\r\n                    </div>\r\n                    <div class=\"coach-footer\">\r\n                        <a th:href=\"@{/teams/{id}(id=${team.id})}\" class=\"btn-coach-action btn-view-profile w-100\">\r\n                            Подробнее\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<div th:replace=\"layout/footer :: footer\"></div>\r\n<script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\r\n\r\n</body>\r\n</html>
