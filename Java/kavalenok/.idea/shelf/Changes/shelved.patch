<+><!DOCTYPE html>\r\n<html lang=\"ru\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>RentRadar - Разместить объявление</title>\r\n    <link rel=\"stylesheet\" href=\"/static/css/style.css\">\r\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\" />\r\n    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"></script>\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\r\n    <style>\r\n        .listing-type-selector {\r\n            display: flex;\r\n            gap: 16px;\r\n            margin-bottom: 30px;\r\n            background: white;\r\n            padding: 8px;\r\n            border-radius: 60px;\r\n            border: 1px solid var(--border-color);\r\n            max-width: 400px;\r\n            margin-left: auto;\r\n            margin-right: auto;\r\n        }\r\n\r\n        .type-btn {\r\n            flex: 1;\r\n            padding: 14px 24px;\r\n            border: none;\r\n            background: transparent;\r\n            border-radius: 50px;\r\n            font-size: 1.1rem;\r\n            font-weight: 600;\r\n            color: var(--text-muted);\r\n            cursor: pointer;\r\n            transition: all 0.3s ease;\r\n        }\r\n\r\n        .type-btn.active {\r\n            background: linear-gradient(135deg, var(--primary-teal), var(--primary-light));\r\n            color: white;\r\n            box-shadow: 0 4px 10px rgba(44, 120, 115, 0.3);\r\n        }\r\n\r\n        .hidden {\r\n            display: none !important;\r\n        }\r\n\r\n        .error-message {\r\n            color: #dc3545;\r\n            font-size: 0.8rem;\r\n            margin-top: 5px;\r\n            display: block;\r\n        }\r\n\r\n        .photo-preview-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\r\n            gap: 16px;\r\n            margin-top: 16px;\r\n        }\r\n\r\n        .photo-preview-item img {\r\n            width: 100%;\r\n            height: 100%;\r\n            object-fit: cover;\r\n        }\r\n\r\n\r\n        .photo-upload-area {\r\n            background: #f8fafd;\r\n            border: 2px dashed var(--border-color);\r\n            border-radius: 16px;\r\n            padding: 48px 32px;\r\n            text-align: center;\r\n            cursor: pointer;\r\n            transition: all 0.3s;\r\n            margin-bottom: 24px;\r\n        }\r\n\r\n        .photo-upload-area:hover {\r\n            border-color: var(--primary-teal);\r\n            background: white;\r\n        }\r\n\r\n        .photo-upload-area.drag-over {\r\n            border-color: var(--primary-teal);\r\n            background: #e8f3f2;\r\n        }\r\n\r\n        #description {\r\n            resize: none;\r\n            min-height: 120px;\r\n            max-height: 18rem;\r\n            overflow-y: auto;\r\n            line-height: 1.5;\r\n        }\r\n\r\n        .amenities-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\r\n            gap: 16px;\r\n        }\r\n\r\n\r\n\r\n        .success-message i {\r\n            font-size: 1.2rem;\r\n        }\r\n\r\n        .listing-loc-map {\r\n            height: 280px;\r\n            border-radius: 12px;\r\n            border: 1px solid var(--border-color);\r\n            z-index: 1;\r\n        }\r\n\r\n        #citySelect:invalid {\r\n            color: var(--text-muted);\r\n        }\r\n\r\n        #citySelect option {\r\n            color: var(--text-dark);\r\n        }\r\n\r\n        .price-period-switch {\r\n            display: inline-flex;\r\n            gap: 8px;\r\n            background: #f4f7f7;\r\n            border: 1px solid var(--border-color);\r\n            border-radius: 999px;\r\n            padding: 4px;\r\n        }\r\n\r\n        .price-period-btn {\r\n            border: none;\r\n            background: transparent;\r\n            padding: 8px 14px;\r\n            border-radius: 999px;\r\n            font-weight: 600;\r\n            color: var(--text-muted);\r\n            cursor: pointer;\r\n        }\r\n\r\n        .price-period-btn.active {\r\n            background: var(--primary-teal);\r\n            color: #fff;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n<header class=\"header\">\r\n    <div class=\"container header-container\"></div>\r\n</header>\r\n\r\n\r\n<main>\r\n    <div class=\"container\">\r\n        <div class=\"page-header\">\r\n            <h1 class=\"page-title\" id=\"createPageTitle\">Разместить объявление</h1>\r\n            <p class=\"page-subtitle\" id=\"createPageSubtitle\">Заполните информацию о вашем объекте недвижимости</p>\r\n        </div>\r\n\r\n        <div id=\"formMessages\"></div>\r\n\r\n        <div class=\"listing-type-selector\">\r\n            <button type=\"button\" class=\"type-btn active\" id=\"rentTypeBtn\">\r\n                <i class=\"fas fa-calendar-alt\"></i> Аренда\r\n            </button>\r\n            <button type=\"button\" class=\"type-btn\" id=\"saleTypeBtn\">\r\n                <i class=\"fas fa-tag\"></i> Продажа\r\n            </button>\r\n        </div>\r\n\r\n        <form class=\"listing-form\" id=\"createListingForm\">\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-info-circle\"></i> Основная информация\r\n                </h2>\r\n                <div class=\"form-grid\">\r\n                    <div class=\"form-group full-width\">\r\n                        <label for=\"listingTitle\">Название объявления *</label>\r\n                        <input type=\"text\" id=\"listingTitle\" placeholder=\"Например: Уютная 1-комнатная квартира в центре\">\r\n                        <div class=\"error-message\" id=\"titleError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group\">\r\n                        <label for=\"propertyType\">Тип жилья *</label>\r\n                        <select id=\"propertyType\">\r\n                            <option value=\"\">Выберите тип</option>\r\n                            <option value=\"apartment\">Квартира</option>\r\n                            <option value=\"room\">Комната</option>\r\n                            <option value=\"house\">Дом</option>\r\n                        </select>\r\n                        <div class=\"error-message\" id=\"propertyTypeError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group\">\r\n                        <label for=\"rooms\">Комнат *</label>\r\n                        <select id=\"rooms\">\r\n                            <option value=\"\">Выберите количество</option>\r\n                            <option value=\"1\">1 комната</option>\r\n                            <option value=\"2\">2 комнаты</option>\r\n                            <option value=\"3\">3 комнаты</option>\r\n                            <option value=\"4\">4 комнаты</option>\r\n                            <option value=\"5\">5+ комнат</option>\r\n                        </select>\r\n                        <div class=\"error-message\" id=\"roomsError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group\">\r\n                        <label for=\"area\">Площадь (м²) *</label>\r\n                        <input type=\"number\" id=\"area\" placeholder=\"Например: 42\" min=\"1\" step=\"0.1\">\r\n                        <div class=\"error-message\" id=\"areaError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group\" id=\"floorFormGroup\">\r\n                        <label for=\"floor\">Этаж *</label>\r\n                        <input type=\"number\" id=\"floor\" placeholder=\"Например: 7\" min=\"1\">\r\n                        <div class=\"error-message\" id=\"floorError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group\">\r\n                        <label for=\"totalFloors\">Этажей в доме *</label>\r\n                        <input type=\"number\" id=\"totalFloors\" placeholder=\"Например: 12\" min=\"1\">\r\n                        <div class=\"error-message\" id=\"totalFloorsError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group sale-only hidden\">\r\n                        <label for=\"houseType\">Тип дома</label>\r\n                        <select id=\"houseType\">\r\n                            <option value=\"\">Выберите тип</option>\r\n                            <option value=\"brick\">Кирпичный</option>\r\n                            <option value=\"panel\">Панельный</option>\r\n                            <option value=\"monolith\">Монолитный</option>\r\n                            <option value=\"block\">Блочный</option>\r\n                            <option value=\"wood\">Деревянный</option>\r\n                        </select>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-map-marker-alt\"></i> Адрес и местоположение\r\n                </h2>\r\n                <div class=\"form-grid\">\r\n                    <div class=\"form-group full-width\">\r\n                        <label for=\"address\">Адрес *</label>\r\n                        <input type=\"text\" id=\"address\" placeholder=\"Город, улица, дом\">\r\n                        <div class=\"error-message\" id=\"addressError\"></div>\r\n                    </div>\r\n                    <div class=\"form-group\">\r\n                        <label for=\"citySelect\">Город *</label>\r\n                        <select id=\"citySelect\" required>\r\n                            <option value=\"\" selected disabled hidden>Выберите город</option>\r\n                        </select>\r\n                        <div class=\"error-message\" id=\"cityError\"></div>\r\n                    </div>\r\n                    <div class=\"form-group full-width hidden\" id=\"cityCustomWrap\">\r\n                        <label for=\"cityCustom\">Другой город *</label>\r\n                        <input type=\"text\" id=\"cityCustom\" placeholder=\"Введите название населённого пункта\" autocomplete=\"address-level2\">\r\n                        <p style=\"font-size: 0.85rem; color: var(--text-muted); margin-top: 6px;\">Показывается, только если выбран пункт «Другой (ввести вручную)».</p>\r\n                    </div>\r\n                    <div class=\"form-group\">\r\n                        <label for=\"district\">Район</label>\r\n                        <input type=\"text\" id=\"district\" placeholder=\"Например: Центральный\">\r\n                    </div>\r\n                    <div class=\"form-group full-width\">\r\n                        <label>Точка на карте *</label>\r\n                        <p style=\"font-size:0.88rem;color:var(--text-muted);margin:0 0 10px;line-height:1.45;\">\r\n                            Нажмите по карте или воспользуйтесь поиском по адресу — так объявление отобразится на карте каталога.\r\n                        </p>\r\n                        <div style=\"display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;align-items:center;\">\r\n                            <button type=\"button\" class=\"btn btn-outline\" id=\"geocodeAddressBtn\">Найти по адресу</button>\r\n                            <span id=\"locationHint\" style=\"font-size:0.85rem;color:var(--text-muted);\"></span>\r\n                        </div>\r\n                        <div id=\"listingLocationMap\" class=\"listing-loc-map\"></div>\r\n                        <input type=\"hidden\" id=\"listingLat\" value=\"\">\r\n                        <input type=\"hidden\" id=\"listingLng\" value=\"\">\r\n                        <div class=\"error-message\" id=\"locationMapError\"></div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-ruble-sign\"></i> Цена и условия\r\n                    <span id=\"pricePeriodLabel\" style=\"font-size: 0.9rem;\">(за месяц)</span>\r\n                </h2>\r\n                <div class=\"form-grid\">\r\n                    <div class=\"form-group rent-only\">\r\n                        <label>Период цены *</label>\r\n                        <div class=\"price-period-switch\" id=\"pricePeriodSwitch\">\r\n                            <button type=\"button\" class=\"price-period-btn active\" data-period=\"month\">За месяц</button>\r\n                            <button type=\"button\" class=\"price-period-btn\" data-period=\"day\">За сутки</button>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"form-group\">\r\n                        <label for=\"price\" id=\"priceLabel\">Цена за месяц (BYN) *</label>\r\n                        <input type=\"number\" id=\"price\" placeholder=\"Например: 520\" min=\"1\">\r\n                        <div class=\"error-message\" id=\"priceError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group rent-only\">\r\n                        <label for=\"availableFrom\">Доступно с *</label>\r\n                        <input type=\"date\" id=\"availableFrom\">\r\n                        <div class=\"error-message\" id=\"availableFromError\"></div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group sale-only hidden\">\r\n                        <label for=\"condition\">Состояние</label>\r\n                        <select id=\"condition\">\r\n                            <option value=\"\">Выберите состояние</option>\r\n                            <option value=\"new\">Новостройка</option>\r\n                            <option value=\"renovated\">Сделан ремонт</option>\r\n                            <option value=\"medium\">Среднее</option>\r\n                            <option value=\"requires\">Требует ремонта</option>\r\n                        </select>\r\n                    </div>\r\n\r\n                    <div class=\"form-group sale-only hidden\">\r\n                        <label for=\"buildingYear\">Год постройки</label>\r\n                        <input type=\"number\" id=\"buildingYear\" placeholder=\"Например: 2015\" min=\"1900\" max=\"2026\">\r\n                    </div>\r\n\r\n                    <div class=\"form-group full-width rent-only\">\r\n                        <label>Залог</label>\r\n                        <div class=\"radio-group\">\r\n                            <label class=\"radio-container\">\r\n                                <input type=\"radio\" name=\"deposit\" value=\"none\" checked>\r\n                                <span class=\"radio-mark\"></span> Без залога\r\n                            </label>\r\n                            <label class=\"radio-container\">\r\n                                <input type=\"radio\" name=\"deposit\" value=\"month\">\r\n                                <span class=\"radio-mark\"></span> 1 месяц\r\n                            </label>\r\n                            <label class=\"radio-container\">\r\n                                <input type=\"radio\" name=\"deposit\" value=\"half\">\r\n                                <span class=\"radio-mark\"></span> ½ месяца\r\n                            </label>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"form-group full-width rent-only\">\r\n                        <label>Коммунальные платежи</label>\r\n                        <div class=\"checkbox-group\">\r\n                            <label class=\"checkbox-container\">\r\n                                <input type=\"checkbox\" id=\"utilitiesIncluded\">\r\n                                <span class=\"checkmark\"></span>\r\n                                <span id=\"utilitiesText\">Включены в стоимость</span>\r\n                            </label>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-align-left\"></i> Описание\r\n                </h2>\r\n                <div class=\"form-group full-width\">\r\n                    <label for=\"description\">Описание объявления *</label>\r\n                    <textarea id=\"description\" name=\"description\" rows=\"8\" maxlength=\"1000\" placeholder=\"Расскажите о вашем жилье...\"></textarea>\r\n                    <div class=\"textarea-counter\">0/1000</div>\r\n                    <div class=\"error-message\" id=\"descriptionError\"></div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-camera\"></i> Фотографии\r\n                </h2>\r\n                <div class=\"photo-upload-area\" id=\"photoUploadArea\">\r\n                    <i class=\"fas fa-cloud-upload-alt\" style=\"font-size: 3rem;\"></i>\r\n                    <p>Перетащите фотографии сюда или нажмите для выбора</p>\r\n                    <p class=\"photo-hint\">Максимум 10 фото. Первое фото будет обложкой</p>\r\n                    <p class=\"photo-hint\" id=\"existingPhotosNote\" style=\"display: none;\"></p>\r\n                    <input type=\"file\" id=\"photoInput\" multiple accept=\"image/*\" style=\"display: none;\">\r\n                    <button type=\"button\" class=\"btn btn-outline\" id=\"selectPhotosBtn\" style=\"margin-top: 15px;\">\r\n                        <i class=\"fas fa-folder-open\"></i> Выбрать фотографии\r\n                    </button>\r\n                </div>\r\n                <div class=\"photo-preview-grid\" id=\"photoPreview\"></div>\r\n                <div class=\"error-message\" id=\"photosError\"></div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-couch\"></i> Удобства и особенности\r\n                </h2>\r\n                <div class=\"amenities-grid\">\r\n                    <label class=\"checkbox-container\">\r\n                        <input type=\"checkbox\" id=\"amenityParking\">\r\n                        <span class=\"checkmark\"></span> Парковка\r\n                    </label>\r\n                    <label class=\"checkbox-container\" id=\"amenityElevatorWrap\">\r\n                        <input type=\"checkbox\" id=\"amenityElevator\">\r\n                        <span class=\"checkmark\"></span> Лифт\r\n                    </label>\r\n                    <label class=\"checkbox-container rent-only\">\r\n                        <input type=\"checkbox\" id=\"amenityFurniture\">\r\n                        <span class=\"checkmark\"></span> Мебель\r\n                    </label>\r\n                    <label class=\"checkbox-container rent-only\">\r\n                        <input type=\"checkbox\" id=\"amenityChildren\">\r\n                        <span class=\"checkmark\"></span> Можно с детьми\r\n                    </label>\r\n                    <label class=\"checkbox-container rent-only\">\r\n                        <input type=\"checkbox\" id=\"amenityPets\">\r\n                        <span class=\"checkmark\"></span> Можно с животными\r\n                    </label>\r\n                    <label class=\"checkbox-container rent-only\">\r\n                        <input type=\"checkbox\" id=\"amenityWifi\">\r\n                        <span class=\"checkmark\"></span> Wi-Fi\r\n                    </label>\r\n                    <label class=\"checkbox-container sale-only hidden\">\r\n                        <input type=\"checkbox\" id=\"amenityRenovation\">\r\n                        <span class=\"checkmark\"></span> Евроремонт\r\n                    </label>\r\n                    <label class=\"checkbox-container sale-only hidden\" id=\"amenityNewBuildingWrap\">\r\n                        <input type=\"checkbox\" id=\"amenityNewBuilding\">\r\n                        <span class=\"checkmark\"></span> Новостройка\r\n                    </label>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h2 class=\"form-section-title\">\r\n                    <i class=\"fas fa-phone-alt\"></i> Контактная информация\r\n                </h2>\r\n                <div class=\"form-grid\">\r\n                    <div class=\"form-group full-width\">\r\n                        <label for=\"contactName\">Контактное лицо *</label>\r\n                        <input type=\"text\" id=\"contactName\" placeholder=\"Как к вам обращаться\">\r\n                        <div class=\"error-message\" id=\"contactNameError\"></div>\r\n                    </div>\r\n                    <div class=\"form-group full-width\">\r\n                        <label for=\"contactPhone\">Телефон *</label>\r\n                        <input type=\"tel\" id=\"contactPhone\" placeholder=\"+375 (29) 123-45-67\">\r\n                        <div class=\"error-message\" id=\"contactPhoneError\"></div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <div class=\"terms-box\">\r\n                    <label class=\"checkbox-container\">\r\n                        <input type=\"checkbox\" id=\"agreeTerms\" required>\r\n                        <span class=\"checkmark\"></span>\r\n                        Я подтверждаю, что имею право на сдачу/продажу данной недвижимости и предоставляю достоверную информацию\r\n                    </label>\r\n                    <div class=\"error-message\" id=\"termsError\"></div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"form-actions\">\r\n                <button type=\"button\" class=\"btn btn-outline btn-large\" onclick=\"window.location.href='index.html'\">\r\n                     Отмена\r\n                </button>\r\n                <button type=\"submit\" class=\"btn btn-primary btn-large\" id=\"submitBtn\">\r\n                    Опубликовать\r\n                </button>\r\n            </div>\r\n        </form>\r\n    </div>\r\n</main>\r\n\r\n\r\n<footer class=\"footer\"></footer>\r\n<script src=\"/static/js/components.js\"></script>\r\n\r\n\r\n<script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\" crossorigin=\"\"></script>\r\n<script src=\"/static/js/belarus-cities.js\"></script>\r\n<script src=\"/static/js/script.js\"></script>\r\n<script src=\"/static/js/create-listing.js\"></script>\r\n</body>\r\n</html>
